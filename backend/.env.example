# Supabase: Dashboard → Project Settings → API
# Database: Dashboard → Project Settings → Database → Connection string

# --- Supabase (Auth + API) ---

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Postgres (direct DB access for retrieval queries) ---

# Use the DIRECT connection (host: db.<ref>.supabase.co).
# URL-encode special characters in the password.

DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# --- OpenAI ---

OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_GROUNDING_MODEL=gpt-4o-mini
OPENAI_AGENT_REQUEST_LIMIT=20
OPENAI_AGENT_TEMPERATURE=0

# --- Retrieval (hybrid search defaults) ---

RETRIEVAL_CANDIDATE_K=50
RETRIEVAL_TOP_K=10
RETRIEVAL_RRF_K=60
RETRIEVAL_NEIGHBOR_RADIUS=1
RETRIEVAL_FTS_CONFIG=english
RETRIEVAL_FTS_KEYWORD_MODEL=gpt-4o-mini
RETRIEVAL_FTS_KEYWORD_MIN=3
RETRIEVAL_FTS_KEYWORD_MAX=5
RETRIEVAL_FTS_KEYWORD_FAST_PATH_TOKENS=5

# --- Server ---

ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
PORT=8000
